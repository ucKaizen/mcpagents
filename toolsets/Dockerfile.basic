FROM python:3.12-slim
WORKDIR /app

RUN pip install --no-cache-dir \
    "fastapi>=0.111.0" \
    "uvicorn>=0.30.0" \
    "pydantic>=2.7.0" \
    "httpx>=0.27.0"

COPY server/media_data.py server/media_data.py
COPY toolsets/basic_metrics.py toolsets/basic_metrics.py

EXPOSE 8002
CMD ["python", "toolsets/basic_metrics.py"]
